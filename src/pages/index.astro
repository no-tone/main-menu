---
import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { ALL_TAGS, APPS } from "../apps";
import { Image } from "astro:assets";

const EAGER_ICON_COUNT = 8;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <header class="topbar">
      <nav class="topbar__nav" aria-label="Primary">
        <span class="topbar__title">self-hosted/</span>
        <button
          class="topbar__toggle"
          type="button"
          aria-label="Toggle theme"
          title="Toggle theme"
        >
          <span class="topbar__toggleIcon" aria-hidden="true">☀︎</span>
        </button>
        <span></span>
      </nav>
    </header>

    <main class="launcher" aria-label="Self-hosted applications">
      <section class="launcher__window" aria-labelledby="launcher-title">
        <header class="launcher__titlebar">
          <h1 class="launcher__title" id="launcher-title">self-hosted/</h1>
          <span class="launcher__note">no-tone</span>
          <button
            class="refresh"
            id="refresh"
            type="button"
            aria-label="Refresh statuses"
            title="Refresh statuses"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M17.65 6.35A7.95 7.95 0 0012 4a8 8 0 108 8h-2a6 6 0 11-6-6c1.66 0 3.14.69 4.22 1.78L14 10h6V4l-2.35 2.35z"
              ></path>
            </svg>
          </button>
        </header>

        <section class="controls" aria-label="Search and filters">
          <label class="field" for="q">
            <span class="label">search</span>
            <span class="fieldControl">
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M10 4a6 6 0 104.472 10.03l4.249 4.25 1.414-1.415-4.25-4.249A6 6 0 0010 4zm0 2a4 4 0 110 8 4 4 0 010-8z"
                ></path>
              </svg>
              <input
                id="q"
                name="q"
                type="search"
                placeholder="Search apps"
                autocomplete="off"
              />
            </span>
          </label>

          <label class="field" for="tag">
            <span class="label">tag</span>
            <span class="fieldControl select">
              <select id="tag" name="tag">
                <option value="">all</option>
                {ALL_TAGS.map((t) => <option value={t}>{t}</option>)}
              </select>
            </span>
          </label>

          <div class="meta" aria-live="polite">
            <span id="count"></span>
          </div>
        </section>

        <section class="grid" id="grid" aria-label="Apps">
          {
            APPS.map((app, i) => (
              <a
                class="tile"
                href={app.href}
                target="_blank"
                rel="noopener noreferrer"
                data-name={app.name.toLowerCase()}
                data-href={app.href}
                data-tags={app.tags.join(",")}
              >
                <div class="tile-inner">
                  <div class="logo" aria-hidden="true">
                    <Image
                      src={app.iconUrl}
                      width={44}
                      height={44}
                      alt=""
                      loading={i < EAGER_ICON_COUNT ? "eager" : "lazy"}
                      decoding="async"
                      fetchpriority={i < EAGER_ICON_COUNT ? "high" : "auto"}
                    />
                  </div>
                  <div class="appMeta">
                    <div class="name">{app.name}</div>
                    <div class="tags" aria-label={`Tags: ${app.tags.join(", ")}`}>
                      {app.tags.map((t) => <span class="pill">{t}</span>)}
                    </div>
                  </div>
                  <div
                    class="status"
                    data-status="unknown"
                    role="status"
                    aria-label="Status: unknown"
                  >
                    <span class="dot" aria-hidden="true" />
                    <span class="text">?</span>
                  </div>
                </div>
              </a>
            ))
          }
        </section>

        <p class="empty" id="empty" hidden>No matches.</p>
      </section>
    </main>

    <footer class="bottombar">
      <nav class="bottombar__nav" aria-label="Footer">
        <a
          href="https://no-tone.com"
          target="_blank"
          rel="noopener noreferrer"
          class="bottombar__link">no-tone.com</a
        >
        <span class="bottombar__sep">/</span>
        <a href="/" class="bottombar__link">self-hosted</a>
      </nav>
    </footer>

    <script>
      type Status = "up" | "down" | "vpn" | "checking" | "unknown";
      type ServerStatusValue = "up" | "down" | "unknown";
      type Theme = "dark" | "light";

      const STATUS_REFRESH_MS = 90_000;
      const STATUS_TIMEOUT_MS = 2500;
      const CLIENT_TIMEOUT_MS = 1200;
      const TAILNET_IP_TIMEOUT_MS = 700;
      const TAILNET_IP_CACHE_MS = 30_000;

      const q = document.getElementById("q") as HTMLInputElement | null;
      const tag = document.getElementById("tag") as HTMLSelectElement | null;
      const count = document.getElementById("count");
      const empty = document.getElementById("empty");
      const themeToggle =
        document.querySelector<HTMLButtonElement>(".topbar__toggle");
      const themeIcon =
        document.querySelector<HTMLElement>(".topbar__toggleIcon");
      const refreshBtn = document.getElementById("refresh") as
        | HTMLElement
        | null;

      type Tile = {
        el: HTMLAnchorElement;
        href: string;
        name: string;
        tags: string;
        isSelf: boolean;
        statusEl: HTMLElement;
        statusTextEl: HTMLElement;
      };

      const tiles: Tile[] = Array.from(
        document.querySelectorAll<HTMLAnchorElement>("a.tile[data-name]"),
      ).map((el) => {
        const statusEl = el.querySelector<HTMLElement>(".status");
        const statusTextEl = el.querySelector<HTMLElement>(".status .text");
        if (!statusEl || !statusTextEl) {
          throw new Error("tile missing .status or .status .text");
        }
        const tags = el.dataset.tags ?? "";
        return {
          el,
          href: el.dataset.href ?? el.href,
          name: el.dataset.name ?? "",
          tags,
          isSelf: tags.includes("Self-Hosted"),
          statusEl,
          statusTextEl,
        };
      });

      const readTheme = (): Theme =>
        document.documentElement.dataset.theme === "dark" ? "dark" : "light";

      const applyTheme = (theme: Theme) => {
        document.documentElement.dataset.theme = theme;
        if (themeIcon) themeIcon.textContent = theme === "dark" ? "☾" : "☀︎";
      };

      applyTheme(readTheme());
      themeToggle?.addEventListener("click", () => {
        const next: Theme = readTheme() === "dark" ? "light" : "dark";
        applyTheme(next);
        try {
          localStorage.setItem("theme", next);
        } catch {}
      });

      const applyFilter = () => {
        const query = (q?.value ?? "").trim().toLowerCase();
        const selected = (tag?.value ?? "").trim();
        let visible = 0;
        for (const tile of tiles) {
          const show =
            (!query || tile.name.includes(query)) &&
            (!selected || tile.tags.includes(selected));
          tile.el.hidden = !show;
          if (show) visible++;
        }
        if (count) count.textContent = `${visible} / ${tiles.length}`;
        if (empty) empty.hidden = visible !== 0;
      };

      q?.addEventListener("input", applyFilter);
      tag?.addEventListener("change", applyFilter);
      applyFilter();

      window.addEventListener("keydown", (e) => {
        if (e.key === "/" && document.activeElement !== q) {
          e.preventDefault();
          q?.focus();
        }
      });

      const STATUS_LABEL: Record<Status, string> = {
        up: "up",
        down: "down",
        vpn: "vpn",
        checking: "...",
        unknown: "?",
      };

      const setTileStatus = (tile: Tile, status: Status) => {
        tile.statusEl.dataset.status = status;
        tile.statusEl.setAttribute("aria-label", `Status: ${status}`);
        tile.statusTextEl.textContent = STATUS_LABEL[status];
      };

      const pingUrl = async (href: string, timeoutMs: number): Promise<boolean> => {
        let url: URL;
        try {
          url = new URL(href);
        } catch {
          return false;
        }
        const c = new AbortController();
        const t = setTimeout(() => c.abort(), timeoutMs);
        try {
          const path = url.hostname === "pass.no-tone.com" ? "/favicon.ico" : "/";
          await fetch(new URL(path, url), {
            mode: "no-cors",
            cache: "no-store",
            signal: c.signal,
          });
          return true;
        } catch {
          return false;
        } finally {
          clearTimeout(t);
        }
      };

      let tailnetPromise: Promise<boolean> | null = null;
      let tailnetPromiseAt = 0;
      const hasTailnetIP = (): Promise<boolean> => {
        const now = Date.now();
        if (tailnetPromise && now - tailnetPromiseAt < TAILNET_IP_CACHE_MS) {
          return tailnetPromise;
        }
        tailnetPromiseAt = now;
        tailnetPromise = new Promise<boolean>((resolve) => {
          try {
            const pc = new RTCPeerConnection({ iceServers: [] });
            const done = (v: boolean) => {
              try {
                pc.onicecandidate = null;
                pc.close();
              } catch {}
              resolve(v);
            };
            const timer = setTimeout(() => done(false), TAILNET_IP_TIMEOUT_MS);

            const isTailnet = (ip: string | undefined) => {
              if (!ip) return false;
              if (ip.startsWith("fd7a:115c:a1e0")) return true;
              const m = ip.match(/^(\d{1,3})\.(\d{1,3})\./);
              if (!m) return false;
              return +m[1] === 100 && +m[2] >= 64 && +m[2] <= 127;
            };

            pc.createDataChannel("x");
            pc.onicecandidate = (e) => {
              const cand = e.candidate?.candidate;
              if (!cand) return;
              const ip4 = cand.match(/(\d{1,3}(?:\.\d{1,3}){3})/)?.[1];
              const ip6 = cand.match(/([0-9a-fA-F:]{2,})/)?.[1];
              if (isTailnet(ip4) || isTailnet(ip6)) {
                clearTimeout(timer);
                done(true);
              }
            };
            pc.createOffer()
              .then((o) => pc.setLocalDescription(o))
              .catch(() => {
                clearTimeout(timer);
                done(false);
              });
          } catch {
            resolve(false);
          }
        });
        return tailnetPromise;
      };

      type ServerStatus = {
        apps: Map<string, ServerStatusValue>;
        tailnetDeviceOnline: boolean | null;
      };

      const serverStatuses = async (): Promise<ServerStatus> => {
        const c = new AbortController();
        const t = setTimeout(() => c.abort(), STATUS_TIMEOUT_MS);
        try {
          const res = await fetch("/api/status.json", {
            cache: "no-store",
            signal: c.signal,
          });
          if (!res.ok) return { apps: new Map(), tailnetDeviceOnline: null };
          const data = (await res.json()) as {
            apps?: { href: string; status: ServerStatusValue }[];
            tailnet?: { device?: { online?: boolean } };
          };
          return {
            apps: new Map((data.apps ?? []).map((a) => [a.href, a.status])),
            tailnetDeviceOnline:
              typeof data.tailnet?.device?.online === "boolean"
                ? data.tailnet.device.online
                : null,
          };
        } catch {
          return { apps: new Map(), tailnetDeviceOnline: null };
        } finally {
          clearTimeout(t);
        }
      };

      const checkStatuses = async () => {
        const visible = tiles.filter((tile) => !tile.el.hidden);
        if (visible.length === 0) return;
        for (const tile of visible) setTileStatus(tile, "checking");
        const [server, onTailnet] = await Promise.all([
          serverStatuses(),
          hasTailnetIP(),
        ]);
        await Promise.all(
          visible.map(async (tile) => {
            const serverStatus = server.apps.get(tile.href);
            if (serverStatus === "up") return setTileStatus(tile, "up");
            if (tile.isSelf && server.tailnetDeviceOnline === false) {
              return setTileStatus(tile, "down");
            }
            const ok = await pingUrl(
              tile.href,
              tile.isSelf ? CLIENT_TIMEOUT_MS : STATUS_TIMEOUT_MS,
            );
            if (!tile.isSelf) return setTileStatus(tile, ok ? "up" : "down");
            if (ok) return setTileStatus(tile, "up");
            setTileStatus(tile, onTailnet ? "down" : "vpn");
          }),
        );
      };

      let statusRunning = false;
      const runStatusCheck = () => {
        if (statusRunning) return;
        statusRunning = true;
        checkStatuses().finally(() => {
          statusRunning = false;
        });
      };

      if (refreshBtn) {
        refreshBtn.addEventListener("click", () => {
          refreshBtn.classList.remove("spinning");
          void refreshBtn.offsetWidth;
          refreshBtn.classList.add("spinning");
          runStatusCheck();
        });
        refreshBtn.addEventListener("animationend", () =>
          refreshBtn.classList.remove("spinning"),
        );
      }

      let intervalId: ReturnType<typeof setInterval> | null = null;
      const startInterval = () => {
        if (intervalId !== null) return;
        intervalId = setInterval(runStatusCheck, STATUS_REFRESH_MS);
      };
      const stopInterval = () => {
        if (intervalId === null) return;
        clearInterval(intervalId);
        intervalId = null;
      };

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          stopInterval();
        } else if (intervalId === null) {
          runStatusCheck();
          startInterval();
        }
      });

      runStatusCheck();
      startInterval();
    </script>
  </body>
</html>
